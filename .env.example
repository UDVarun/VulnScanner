# VulnScanner Environment Configuration
# Copy this file to .env and fill in values

# ── MongoDB ──────────────────────────────────────────────
# Default: auto-configured by docker-compose. Only change for external MongoDB.
MONGO_URI=mongodb://mongodb:27017/vulnscanner

# ── Backend ───────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=production

# ── NVD API Key (Optional but recommended) ─────────────────
# Register at: https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 requests/30s rate limit (still works but slower)
# With a key   : 50 requests/30s
NVD_API_KEY=
